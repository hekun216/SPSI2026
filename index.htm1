<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>车辆管理台账系统</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            color: #fff;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        
        /* 头部样式 */
        .header {
            text-align: center;
            padding: 40px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 30px;
        }
        .header h1 { font-size: 2.5rem; margin-bottom: 10px; color: #88B5AE; }
        .header p { color: rgba(255,255,255,0.6); }
        
        /* 统计卡片 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: rgba(136,181,174,0.1);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(136,181,174,0.2);
        }
        .stat-card .number {
            font-size: 2.5rem;
            font-weight: bold;
            color: #88B5AE;
        }
        .stat-card .label { color: rgba(255,255,255,0.6); margin-top: 5px; }
        
        /* 导航标签 */
        .nav-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 10px;
        }
        .nav-tab {
            padding: 12px 24px;
            background: rgba(255,255,255,0.05);
            border: none;
            border-radius: 8px;
            color: rgba(255,255,255,0.7);
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1rem;
        }
        .nav-tab:hover { background: rgba(136,181,174,0.2); }
        .nav-tab.active {
            background: rgba(136,181,174,0.3);
            color: #88B5AE;
        }
        
        /* 内容区域 */
        .content-section { display: none; }
        .content-section.active { display: block; }
        
        /* 按钮样式 */
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }
        .btn-primary {
            background: #88B5AE;
            color: #fff;
        }
        .btn-primary:hover { background: #6a9a93; }
        .btn-danger {
            background: rgba(234,102,104,0.8);
            color: #fff;
        }
        .btn-danger:hover { background: rgba(234,102,104,1); }
        .btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.2); }
        
        /* 表单样式 */
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: rgba(255,255,255,0.8);
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            color: #fff;
            font-size: 1rem;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #88B5AE;
        }
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        /* 卡片样式 */
        .card {
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .card-title { font-size: 1.2rem; color: #88B5AE; }
        
        /* 表格样式 */
        .table-container {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        th {
            background: rgba(136,181,174,0.1);
            color: #88B5AE;
            font-weight: 600;
        }
        tr:hover { background: rgba(255,255,255,0.02); }
        
        /* 模态框 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal.active { display: flex; }
        .modal-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border-radius: 16px;
            padding: 30px;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            border: 1px solid rgba(136,181,174,0.3);
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .modal-title { font-size: 1.5rem; color: #88B5AE; }
        .close-btn {
            background: none;
            border: none;
            color: rgba(255,255,255,0.6);
            font-size: 1.5rem;
            cursor: pointer;
        }
        
        /* 状态标签 */
        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
        }
        .status-normal {
            background: rgba(82,196,26,0.2);
            color: #52C41A;
        }
        .status-warning {
            background: rgba(250,173,20,0.2);
            color: #FAAD14;
        }
        .status-danger {
            background: rgba(234,102,104,0.2);
            color: #EA6668;
        }
        
        /* 搜索框 */
        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        .search-box input {
            flex: 1;
            padding: 12px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            color: #fff;
        }
        
        /* 空状态 */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255,255,255,0.5);
        }
        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }
        
        /* 响应式 */
        @media (max-width: 768px) {
            .header h1 { font-size: 1.8rem; }
            .nav-tabs { flex-wrap: wrap; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .form-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部 -->
        <div class="header">
            <h1>🚗 车辆管理台账系统</h1>
            <p>企业车辆信息管理与检查台账综合平台</p>
        </div>
        
        <!-- 统计卡片 -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="number" id="totalVehicles">0</div>
                <div class="label">车辆总数</div>
            </div>
            <div class="stat-card">
                <div class="number" id="normalVehicles">0</div>
                <div class="label">正常状态</div>
            </div>
            <div class="stat-card">
                <div class="number" id="warningVehicles">0</div>
                <div class="label">需检查</div>
            </div>
            <div class="stat-card">
                <div class="number" id="totalInspections">0</div>
                <div class="label">检查记录</div>
            </div>
        </div>
        
        <!-- 导航标签 -->
        <div class="nav-tabs">
            <button class="nav-tab active" onclick="showSection('vehicles')">🚗 车辆管理</button>
            <button class="nav-tab" onclick="showSection('inspections')">📋 检查台账</button>
            <button class="nav-tab" onclick="showSection('dashboard')">📊 综合看板</button>
        </div>
        
        <!-- 车辆管理 -->
        <div id="vehicles" class="content-section active">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">车辆列表</span>
                    <button class="btn btn-primary" onclick="openVehicleModal()">+ 添加车辆</button>
                </div>
                <div class="search-box">
                    <input type="text" id="vehicleSearch" placeholder="搜索车牌号、车型或驾驶员..." oninput="searchVehicles()">
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>车牌号</th>
                                <th>车型</th>
                                <th>驾驶员</th>
                                <th>状态</th>
                                <th>下次年检</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody id="vehicleTable"></tbody>
                    </table>
                </div>
                <div id="vehicleEmpty" class="empty-state" style="display: none;">
                    <div class="empty-state-icon">🚗</div>
                    <p>暂无车辆信息，点击"添加车辆"开始录入</p>
                </div>
            </div>
        </div>
        
        <!-- 检查台账 -->
        <div id="inspections" class="content-section">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">检查记录</span>
                    <button class="btn btn-primary" onclick="openInspectionModal()">+ 添加检查记录</button>
                </div>
                <div class="search-box">
                    <input type="text" id="inspectionSearch" placeholder="搜索车牌号或检查项目..." oninput="searchInspections()">
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>日期</th>
                                <th>车牌号</th>
                                <th>检查类型</th>
                                <th>检查结果</th>
                                <th>检查人</th>
                                <th>备注</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody id="inspectionTable"></tbody>
                    </table>
                </div>
                <div id="inspectionEmpty" class="empty-state" style="display: none;">
                    <div class="empty-state-icon">📋</div>
                    <p>暂无检查记录，点击"添加检查记录"开始录入</p>
                </div>
            </div>
        </div>
        
        <!-- 综合看板 -->
        <div id="dashboard" class="content-section">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">即将到期提醒</span>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>车牌号</th>
                                <th>车型</th>
                                <th>到期项目</th>
                                <th>到期日期</th>
                                <th>剩余天数</th>
                            </tr>
                        </thead>
                        <tbody id="alertTable"></tbody>
                    </table>
                </div>
            </div>
            
            <div class="card">
                <div class="card-header">
                    <span class="card-title">车辆状态分布</span>
                </div>
                <div id="statusChart" style="height: 300px; display: flex; align-items: center; justify-content: center;">
                    <canvas id="statusCanvas"></canvas>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 车辆编辑模态框 -->
    <div id="vehicleModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title" id="vehicleModalTitle">添加车辆</span>
                <button class="close-btn" onclick="closeVehicleModal()">×</button>
            </div>
            <form id="vehicleForm" onsubmit="saveVehicle(event)">
                <input type="hidden" id="vehicleId">
                <div class="form-row">
                    <div class="form-group">
                        <label>车牌号 *</label>
                        <input type="text" id="plateNumber" required placeholder="如：京A12345">
                    </div>
                    <div class="form-group">
                        <label>车型 *</label>
                        <input type="text" id="vehicleType" required placeholder="如：丰田凯美瑞">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>驾驶员</label>
                        <input type="text" id="driver" placeholder="驾驶员姓名">
                    </div>
                    <div class="form-group">
                        <label>联系电话</label>
                        <input type="tel" id="phone" placeholder="联系电话">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>购买日期</label>
                        <input type="date" id="purchaseDate">
                    </div>
                    <div class="form-group">
                        <label>下次年检日期</label>
                        <input type="date" id="nextInspection">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>保险到期日</label>
                        <input type="date" id="insuranceExpiry">
                    </div>
                    <div class="form-group">
                        <label>状态</label>
                        <select id="vehicleStatus">
                            <option value="normal">正常</option>
                            <option value="warning">需检查</option>
                            <option value="danger">维修中</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>备注</label>
                    <textarea id="vehicleRemark" rows="3" placeholder="其他备注信息..."></textarea>
                </div>
                <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                    <button type="button" class="btn btn-secondary" onclick="closeVehicleModal()">取消</button>
                    <button type="submit" class="btn btn-primary">保存</button>
                </div>
            </form>
        </div>
    </div>
    
    <!-- 检查记录模态框 -->
    <div id="inspectionModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title" id="inspectionModalTitle">添加检查记录</span>
                <button class="close-btn" onclick="closeInspectionModal()">×</button>
            </div>
            <form id="inspectionForm" onsubmit="saveInspection(event)">
                <input type="hidden" id="inspectionId">
                <div class="form-row">
                    <div class="form-group">
                        <label>检查日期 *</label>
                        <input type="date" id="inspectionDate" required>
                    </div>
                    <div class="form-group">
                        <label>车牌号 *</label>
                        <select id="inspectionPlate" required>
                            <option value="">请选择车辆</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>检查类型 *</label>
                        <select id="inspectionType" required>
                            <option value="日常检查">日常检查</option>
                            <option value="定期检查">定期检查</option>
                            <option value="年检">年检</option>
                            <option value="保养">保养</option>
                            <option value="维修">维修</option>
                            <option value="其他">其他</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>检查结果 *</label>
                        <select id="inspectionResult" required>
                            <option value="合格">合格</option>
                            <option value="不合格">不合格</option>
                            <option value="需整改">需整改</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>检查人 *</label>
                        <input type="text" id="inspector" required placeholder="检查人姓名">
                    </div>
                    <div class="form-group">
                        <label>下次检查日期</label>
                        <input type="date" id="nextInspectionDate">
                    </div>
                </div>
                <div class="form-group">
                    <label>检查内容</label>
                    <textarea id="inspectionContent" rows="2" placeholder="检查的具体项目..."></textarea>
                </div>
                <div class="form-group">
                    <label>备注</label>
                    <textarea id="inspectionRemark" rows="2" placeholder="其他备注信息..."></textarea>
                </div>
                <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                    <button type="button" class="btn btn-secondary" onclick="closeInspectionModal()">取消</button>
                    <button type="submit" class="btn btn-primary">保存</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // 数据存储
        let vehicles = JSON.parse(localStorage.getItem('vehicles')) || [];
        let inspections = JSON.parse(localStorage.getItem('inspections')) || [];
        
        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            renderVehicles();
            renderInspections();
            updateStats();
            renderAlerts();
            drawStatusChart();
            
            // 设置默认日期
            document.getElementById('inspectionDate').valueAsDate = new Date();
        });
        
        // 切换页面
        function showSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            event.target.classList.add('active');
            
            if (sectionId === 'dashboard') {
                renderAlerts();
                drawStatusChart();
            }
        }
        
        // 更新统计
        function updateStats() {
            document.getElementById('totalVehicles').textContent = vehicles.length;
            document.getElementById('normalVehicles').textContent = vehicles.filter(v => v.status === 'normal').length;
            document.getElementById('warningVehicles').textContent = vehicles.filter(v => v.status !== 'normal').length;
            document.getElementById('totalInspections').textContent = inspections.length;
        }
        
        // 渲染车辆列表
        function renderVehicles(searchTerm = '') {
            const tbody = document.getElementById('vehicleTable');
            const emptyDiv = document.getElementById('vehicleEmpty');
            
            let filtered = vehicles;
            if (searchTerm) {
                const term = searchTerm.toLowerCase();
                filtered = vehicles.filter(v => 
                    v.plateNumber.toLowerCase().includes(term) ||
                    v.vehicleType.toLowerCase().includes(term) ||
                    (v.driver && v.driver.toLowerCase().includes(term))
                );
            }
            
            if (filtered.length === 0) {
                tbody.innerHTML = '';
                emptyDiv.style.display = 'block';
                return;
            }
            
            emptyDiv.style.display = 'none';
            tbody.innerHTML = filtered.map(v => {
                const statusClass = v.status === 'normal' ? 'status-normal' : 
                                   v.status === 'warning' ? 'status-warning' : 'status-danger';
                const statusText = v.status === 'normal' ? '正常' : 
                                  v.status === 'warning' ? '需检查' : '维修中';
                return `
                    <tr>
                        <td><strong>v.plateNumber</strong></td><td>{v.vehicleType}</td>
                        <td>v.driver∣∣′−′</td><td><spanclass="status−badge{statusClass}">statusText</span></td><td>{v.nextInspection || '-'}</td>
                        <td>
                            <button class="btn btn-secondary" onclick="editVehicle('v.id′)"style="padding:6px12px;font−size:0.9rem;">编辑</button><buttonclass="btnbtn−danger"onclick="deleteVehicle(′{v.id}')" style="padding: 6px 12px; font-size: 0.9rem; margin-left: 5px;">删除</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }
        
        // 搜索车辆
        function searchVehicles() {
            renderVehicles(document.getElementById('vehicleSearch').value);
        }
        
        // 打开车辆模态框
        function openVehicleModal(vehicle = null) {
            document.getElementById('vehicleModal').classList.add('active');
            document.getElementById('vehicleModalTitle').textContent = vehicle ? '编辑车辆' : '添加车辆';
            
            if (vehicle) {
                document.getElementById('vehicleId').value = vehicle.id;
                document.getElementById('plateNumber').value = vehicle.plateNumber;
                document.getElementById('vehicleType').value = vehicle.vehicleType;
                document.getElementById('driver').value = vehicle.driver || '';
                document.getElementById('phone').value = vehicle.phone || '';
                document.getElementById('purchaseDate').value = vehicle.purchaseDate || '';
                document.getElementById('nextInspection').value = vehicle.nextInspection || '';
                document.getElementById('insuranceExpiry').value = vehicle.insuranceExpiry || '';
                document.getElementById('vehicleStatus').value = vehicle.status || 'normal';
                document.getElementById('vehicleRemark').value = vehicle.remark || '';
            } else {
                document.getElementById('vehicleForm').reset();
                document.getElementById('vehicleId').value = '';
            }
        }
        
        // 关闭车辆模态框
        function closeVehicleModal() {
            document.getElementById('vehicleModal').classList.remove('active');
        }
        
        // 保存车辆
        function saveVehicle(e) {
            e.preventDefault();
            
            const vehicle = {
                id: document.getElementById('vehicleId').value || Date.now().toString(),
                plateNumber: document.getElementById('plateNumber').value,
                vehicleType: document.getElementById('vehicleType').value,
                driver: document.getElementById('driver').value,
                phone: document.getElementById('phone').value,
                purchaseDate: document.getElementById('purchaseDate').value,
                nextInspection: document.getElementById('nextInspection').value,
                insuranceExpiry: document.getElementById('insuranceExpiry').value,
                status: document.getElementById('vehicleStatus').value,
                remark: document.getElementById('vehicleRemark').value
            };
            
            const index = vehicles.findIndex(v => v.id === vehicle.id);
            if (index >= 0) {
                vehicles[index] = vehicle;
            } else {
                vehicles.push(vehicle);
            }
            
            localStorage.setItem('vehicles', JSON.stringify(vehicles));
            renderVehicles();
            updateStats();
            closeVehicleModal();
            updateInspectionPlateSelect();
        }
        
        // 编辑车辆
        function editVehicle(id) {
            const vehicle = vehicles.find(v => v.id === id);
            if (vehicle) openVehicleModal(vehicle);
        }
        
        // 删除车辆
        function deleteVehicle(id) {
            if (confirm('确定要删除这辆车辆吗？相关的检查记录也将被删除。')) {
                vehicles = vehicles.filter(v => v.id !== id);
                inspections = inspections.filter(i => i.plateNumber !== vehicles.find(v => v.id === id)?.plateNumber);
                localStorage.setItem('vehicles', JSON.stringify(vehicles));
                localStorage.setItem('inspections', JSON.stringify(inspections));
                renderVehicles();
                renderInspections();
                updateStats();
                updateInspectionPlateSelect();
            }
        }
        
        // 渲染检查记录
        function renderInspections(searchTerm = '') {
            const tbody = document.getElementById('inspectionTable');
            const emptyDiv = document.getElementById('inspectionEmpty');
            
            let filtered = inspections.sort((a, b) => new Date(b.date) - new Date(a.date));
            if (searchTerm) {
                const term = searchTerm.toLowerCase();
                filtered = filtered.filter(i => 
                    i.plateNumber.toLowerCase().includes(term) ||
                    i.type.toLowerCase().includes(term)
                );
            }
            
            if (filtered.length === 0) {
                tbody.innerHTML = '';
                emptyDiv.style.display = 'block';
                return;
            }
            
            emptyDiv.style.display = 'none';
            tbody.innerHTML = filtered.map(i => {
                const resultClass = i.result === '合格' ? 'status-normal' : 
                                   i.result === '不合格' ? 'status-danger' : 'status-warning';
                return `
                    <tr>
                        <td>i.date</td><td><strong>{i.plateNumber}</strong></td>
                        <td>i.type</td><td><spanclass="status−badge{resultClass}">i.result</span></td><td>{i.inspector}</td>
                        <td>i.remark∣∣′−′</td><td><buttonclass="btnbtn−secondary"onclick="editInspection(′{i.id}')" style="padding: 6px 12px; font-size: 0.9rem;">编辑</button>
                            <button class="btn btn-danger" onclick="deleteInspection('${i.id}')" style="padding: 6px 12px; font-size: 0.9rem; margin-left: 5px;">删除</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }
        
        // 搜索检查记录
        function searchInspections() {
            renderInspections(document.getElementById('inspectionSearch').value);
        }
        
        // 更新检查记录中的车牌选择
        function updateInspectionPlateSelect() {
            const select = document.getElementById('inspectionPlate');
            select.innerHTML = '<option value="">请选择车辆</option>' +
                vehicles.map(v => `<option value="${v.plateNumber}">v.plateNumber−{v.vehicleType}</option>`).join('');
        }
        
        // 打开检查记录模态框
        function openInspectionModal(inspection = null) {
            document.getElementById('inspectionModal').classList.add('active');
            document.getElementById('inspectionModalTitle').textContent = inspection ? '编辑检查记录' : '添加检查记录';
            updateInspectionPlateSelect();
            
            if (inspection) {
                document.getElementById('inspectionId').value = inspection.id;
                document.getElementById('inspectionDate').value = inspection.date;
                document.getElementById('inspectionPlate').value = inspection.plateNumber;
                document.getElementById('inspectionType').value = inspection.type;
                document.getElementById('inspectionResult').value = inspection.result;
                document.getElementById('inspector').value = inspection.inspector;
                document.getElementById('nextInspectionDate').value = inspection.nextDate || '';
                document.getElementById('inspectionContent').value = inspection.content || '';
                document.getElementById('inspectionRemark').value = inspection.remark || '';
            } else {
                document.getElementById('inspectionForm').reset();
                document.getElementById('inspectionId').value = '';
                document.getElementById('inspectionDate').valueAsDate = new Date();
            }
        }
        
        // 关闭检查记录模态框
        function closeInspectionModal() {
            document.getElementById('inspectionModal').classList.remove('active');
        }
        
        // 保存检查记录
        function saveInspection(e) {
            e.preventDefault();
            
            const inspection = {
                id: document.getElementById('inspectionId').value || Date.now().toString(),
                date: document.getElementById('inspectionDate').value,
                plateNumber: document.getElementById('inspectionPlate').value,
                type: document.getElementById('inspectionType').value,
                result: document.getElementById('inspectionResult').value,
                inspector: document.getElementById('inspector').value,
                nextDate: document.getElementById('nextInspectionDate').value,
                content: document.getElementById('inspectionContent').value,
                remark: document.getElementById('inspectionRemark').value
            };
            
            const index = inspections.findIndex(i => i.id === inspection.id);
            if (index >= 0) {
                inspections[index] = inspection;
            } else {
                inspections.push(inspection);
            }
            
            localStorage.setItem('inspections', JSON.stringify(inspections));
            renderInspections();
            updateStats();
            closeInspectionModal();
        }
        
        // 编辑检查记录
        function editInspection(id) {
            const inspection = inspections.find(i => i.id === id);
            if (inspection) openInspectionModal(inspection);
        }
        
        // 删除检查记录
        function deleteInspection(id) {
            if (confirm('确定要删除这条检查记录吗？')) {
                inspections = inspections.filter(i => i.id !== id);
                localStorage.setItem('inspections', JSON.stringify(inspections));
                renderInspections();
                updateStats();
            }
        }
        
        // 渲染到期提醒
        function renderAlerts() {
            const tbody = document.getElementById('alertTable');
            const today = new Date();
            const alerts = [];
            
            vehicles.forEach(v => {
                if (v.nextInspection) {
                    const days = Math.ceil((new Date(v.nextInspection) - today) / (1000 * 60 * 60 * 24));
                    if (days <= 30) {
                        alerts.push({
                            plate: v.plateNumber,
                            type: v.vehicleType,
                            item: '年检',
                            date: v.nextInspection,
                            days: days
                        });
                    }
                }
                if (v.insuranceExpiry) {
                    const days = Math.ceil((new Date(v.insuranceExpiry) - today) / (1000 * 60 * 60 * 24));
                    if (days <= 30) {
                        alerts.push({
                            plate: v.plateNumber,
                            type: v.vehicleType,
                            item: '保险',
                            date: v.insuranceExpiry,
                            days: days
                        });
                    }
                }
            });
            
            alerts.sort((a, b) => a.days - b.days);
            
            if (alerts.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: rgba(255,255,255,0.5);">暂无即将到期的项目</td></tr>';
                return;
            }
            
            tbody.innerHTML = alerts.map(a => {
                const daysClass = a.days < 0 ? 'status-danger' : a.days <= 7 ? 'status-warning' : 'status-normal';
                const daysText = a.days < 0 ? `已过期 Math.abs(a.days)天‘:‘剩余{a.days} 天`;
                return `
                    <tr>
                        <td><strong>a.plate</strong></td><td>{a.type}</td>
                        <td>a.item</td><td>{a.date}</td>
                        <td><span class="status-badge daysClass">{daysText}</span></td>
                    </tr>
                `;
            }).join('');
        }
        
        // 绘制状态分布图
        function drawStatusChart() {
            const canvas = document.getElementById('statusCanvas');
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            const container = document.getElementById('statusChart');
            canvas.width = container.offsetWidth;
            canvas.height = 300;
            
            const normal = vehicles.filter(v => v.status === 'normal').length;
            const warning = vehicles.filter(v => v.status === 'warning').length;
            const danger = vehicles.filter(v => v.status === 'danger').length;
            const total = vehicles.length;
            
            if (total === 0) {
                ctx.fillStyle = 'rgba(255,255,255,0.5)';
                ctx.font = '16px sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText('暂无数据', canvas.width / 2, canvas.height / 2);
                return;
            }
            
            const data = [
                { label: '正常', value: normal, color: '#52C41A' },
                { label: '需检查', value: warning, color: '#FAAD14' },
                { label: '维修中', value: danger, color: '#EA6668' }
            ];
            
            const centerX = canvas.width / 2 - 100;
            const centerY = canvas.height / 2;
            const radius = 80;
            let currentAngle = -Math.PI / 2;
            
            data.forEach(item => {
                if (item.value > 0) {
                    const angle = (item.value / total) * Math.PI * 2;
                    
                    ctx.beginPath();
                    ctx.moveTo(centerX, centerY);
                    ctx.arc(centerX, centerY, radius, currentAngle, currentAngle + angle);
                    ctx.closePath();
                    ctx.fillStyle = item.color;
                    ctx.fill();
                    
                    currentAngle += angle;
                }
            });
            
            // 绘制图例
            let legendY = centerY - 40;
            data.forEach(item => {
                if (item.value > 0) {
                    ctx.fillStyle = item.color;
                    ctx.fillRect(centerX + 120, legendY, 16, 16);
                    
                    ctx.fillStyle = 'rgba(255,255,255,0.8)';
                    ctx.font = '14px sans-serif';
                    ctx.textAlign = 'left';
                    ctx.fillText(`item.label:{item.value} (${Math.round(item.value/total*100)}%)`, centerX + 145, legendY + 12);
                    
                    legendY += 30;
                }
            });
        }
        
        // 点击模态框外部关闭
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('active');
            }
        }
    </script>
</body>
</html>